{
  "version": 2,
  "name": "activity-checkin",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frame.png", 
      "use": "@vercel/static"
    },
    {
      "src": "api/signature.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/signature.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
